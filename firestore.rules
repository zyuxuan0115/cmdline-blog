rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Replace with the UID of your admin's Firebase Auth account.
    // Must match ADMIN_UID in admin/index.html, dashboard.html, user-documents.html.
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'BqXArSXr1pWbYkAo5FTCzDPFESH2';
    }

    // Documents are keyed by their filename (a 256-bit random hex id).
    match /documents/{filename} {
      // Public docs: anyone. Private docs: the owner. Admin: everything.
      allow read: if resource.data.visibility == 'public'
                  || (request.auth != null && request.auth.uid == resource.data.user_id)
                  || isAdmin();

      // A user may only create docs they own.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.user_id;

      // Owners may modify their own docs.
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.user_id;

      // Owners (or the admin) may delete.
      allow delete: if (request.auth != null && request.auth.uid == resource.data.user_id)
                    || isAdmin();
    }

    // User profile mirror — lets the admin dashboard list registered users
    // (Firebase Auth's user list is not readable from the client).
    match /users/{uid} {
      // Each user reads/writes only their own profile; the admin reads all.
      allow read: if (request.auth != null && request.auth.uid == uid) || isAdmin();
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if (request.auth != null && request.auth.uid == uid) || isAdmin();
    }

    // Direct messages, including friend requests and their accept notifications.
    match /messages/{msgId} {
      // Sender and recipient may read a message.
      allow read: if request.auth != null
                  && (resource.data.to_uid == request.auth.uid
                      || resource.data.from_uid == request.auth.uid);

      // A user may only send messages authored by themselves, to someone else.
      allow create: if request.auth != null
                    && request.resource.data.from_uid == request.auth.uid
                    && request.resource.data.to_uid is string
                    && request.resource.data.to_uid != request.auth.uid;

      // Only the recipient may change a message (accept/ignore, mark read).
      allow update: if request.auth != null
                    && resource.data.to_uid == request.auth.uid
                    && request.resource.data.to_uid == resource.data.to_uid
                    && request.resource.data.from_uid == resource.data.from_uid;

      // Either party may remove a message from their view.
      allow delete: if request.auth != null
                    && (resource.data.to_uid == request.auth.uid
                        || resource.data.from_uid == request.auth.uid);
    }

    // Friendships — one document per pair, id is the two uids sorted and joined
    // with '_'. A single shared doc keeps friendship symmetric while still
    // satisfying per-user write rules (the accepter creates it with both uids).
    match /friendships/{pairId} {
      // `resource == null` allows a get() of a not-yet-existing pair doc (used to
      // check "are we already friends?") — it simply returns "does not exist".
      allow read:   if request.auth != null
                    && (resource == null || request.auth.uid in resource.data.users);
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.users
                    && request.resource.data.users.size() == 2;
      allow delete: if request.auth != null && request.auth.uid in resource.data.users;
      allow update: if false;
    }

    // Username → uid mapping so users can be addressed by name (e.g.
    // `friend <username>`). The doc id is the lowercased username and it holds
    // only { uid, username } — never the email — so it is safe to look up.
    match /usernames/{name} {
      // A single lookup is public (needed during registration, before sign-in);
      // enumeration is not.
      allow get:  if true;
      allow list: if false;
      // You may only claim a name that maps to yourself, and only while it is
      // free (create fails when the doc exists, and updates are forbidden), so
      // usernames stay unique and can't be hijacked.
      // A user claims their own name; the admin may backfill mappings for
      // existing accounts (uid points at the account, not the admin).
      allow create: if (request.auth != null && request.resource.data.uid == request.auth.uid)
                    || isAdmin();
      allow update: if false;
      allow delete: if (request.auth != null && resource.data.uid == request.auth.uid) || isAdmin();
    }

    // Invitation codes are looked up by id during registration (before sign-in),
    // so a direct get() must be allowed — but listing/enumeration is not.
    match /invitation_codes/{code} {
      allow get: if true;
      allow list, write: if false;
    }
  }
}
